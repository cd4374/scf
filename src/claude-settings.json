{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/pre-write-gate.sh\"",
            "description": "Block reviewer agents from writing draft.tex"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-word-count.sh\"",
            "description": "Track word count"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-section-check.sh\"",
            "description": "Verify required sections"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-figure-check.sh\"",
            "description": "Verify figures exist"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-citation-check.sh\"",
            "description": "Validate bib fields"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-latex-check.sh\"",
            "description": "Check LaTeX compile"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-ai-pattern-check.sh\"",
            "description": "Warn on AI writing patterns"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/loop-progress-log.sh\"",
            "description": "Log loop progress"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/stop-gate.sh\"",
            "description": "Final pipeline validation"
          }
        ]
      }
    ]
  }
}
