{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/pre-write-gate.sh\"",
            "description": "Block reviewer agents from writing draft.tex"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/pre-experiment-gate.sh\"",
            "description": "Check env.json validated before experiment execution"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-page-count.sh\"",
            "description": "Check page count against paper-type.page_limit"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-section-check.sh\"",
            "description": "Verify required sections including Limitations"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-figure-check.sh\"",
            "description": "Verify figures exist and count"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-table-check.sh\"",
            "description": "Verify table count"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-citation-check.sh\"",
            "description": "Validate bib fields"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-stat-check.sh\"",
            "description": "Check statistical compliance warnings"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-latex-check.sh\"",
            "description": "Check LaTeX compile"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/post-write-ai-pattern-check.sh\"",
            "description": "Warn on AI writing patterns"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/loop-progress-log.sh\"",
            "description": "Log loop progress"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.arc/hooks/stop-gate.sh\"",
            "description": "Final pipeline validation"
          }
        ]
      }
    ]
  }
}
