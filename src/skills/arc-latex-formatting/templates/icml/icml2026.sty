% icml2026.sty
% Style file for ICML 2026
% Based on the official ICML template

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2026}[2025/01/01 ICML 2026 style file]

% Options
\newif\if@icmlfinal\@icmlfinalfalse
\newif\if@preprint\@preprintfalse
\newif\if@accepted\@acceptedfalse

\DeclareOption{accepted}{\@icmlfinaltrue\@acceptedtrue}
\DeclareOption{preprint}{\@preprinttrue}
\ProcessOptions

% Required packages
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage{times}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage{booktabs}
\RequirePackage{graphicx}
\RequirePackage{fancyhdr}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}

% Page geometry
\RequirePackage[letterpaper, text={6.75in,9in}]{geometry}

% Line spacing
\RequirePackage{setspace}
\setstretch{1.0}

% Bibliography
\RequirePackage[numbers]{natbib}

% Header
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\textit{ICML 2026}}
\fancyhead[R]{\small\thepage}
\renewcommand{\headrulewidth}{0pt}

% Title formatting
\newcommand{\icmltitle}[1]{\def\@icmltitle{#1}}
\newcommand{\icmlauthor}[2]{}
\newcommand{\icmlaffiliation}[1]{}
\newcommand{\icmlcorrespondingauthor}[2]{}
\newcommand{\icmlkeywords}[1]{}
\newcommand{\icmltitlerunning}[1]{}
\newcommand{\icmlsetsymbol}[2]{}

% Custom maketitle
\renewcommand{\maketitle}{%
  \begin{center}
  {\Large\bfseries\@icmltitle\par}
  \end{center}
  \vspace{0.3in}
}

% Abstract formatting
\renewenvironment{abstract}{%
  \begin{center}
  \begin{minipage}{0.9\textwidth}
  \small
}{%
  \end{minipage}
  \end{center}
  \vspace{0.5em}
}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Theorem environments
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{assumption}[theorem]{Assumption}
\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}

% Line numbers for review
\if@accepted
\else
  \RequirePackage{lineno}
  \linenumbers
\fi

% Colors and hyperref
\definecolor{darkblue}{rgb}{0,0,0.5}
\hypersetup{
  colorlinks=true,
  linkcolor=darkblue,
  citecolor=darkblue,
  urlcolor=darkblue
}

% End of style file
\endinput
